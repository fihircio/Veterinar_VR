*.cs text diff=csharp
*.shader text
*.cginc text
*.hlsl text
*.compute text
*.uxml text
*.uss text
*.asmdef text
*.asmref text
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
